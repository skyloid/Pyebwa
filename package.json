{
  "name": "pyebwa-app",
  "version": "2.0.0",
  "description": "Pyebwa Family Tree Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "psql $DATABASE_URL < server/db/schema.sql",
    "db:init:supabase": "cat server/db/schema.sql | docker exec -i supabase-db psql -U postgres -d postgres",
    "version:sync": "node scripts/sync-version.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:theme": "jest __tests__/theme-toggle-simple.test.js __tests__/theme-integration.test.js",
    "test:theme:watch": "jest __tests__/theme-toggle-simple.test.js __tests__/theme-integration.test.js --watch",
    "test:theme:coverage": "jest __tests__/theme-toggle-simple.test.js __tests__/theme-integration.test.js --coverage",
    "test:theme:jsdom": "jest --config jest.config.dom.js __tests__/theme-toggle.test.js __tests__/pyebwa-site-theme.test.js",
    "lint": "eslint app/js/ server/ --ext .js",
    "lint:fix": "eslint app/js/ server/ --ext .js --fix",
    "format": "prettier --write \"app/js/**/*.js\" \"server/**/*.js\"",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:check": "npm audit --audit-level moderate",
    "outdated:check": "npm outdated"
  },
  "keywords": [
    "family-tree",
    "genealogy",
    "haiti"
  ],
  "author": "Pyebwa",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^8.1.5",
    "@supabase/supabase-js": "^2.101.1",
    "archiver": "^5.3.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.5",
    "isomorphic-dompurify": "^2.9.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "standardwebhooks": "^1.0.0",
    "uuid": "^11.0.0",
    "validator": "^13.11.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@testing-library/jest-dom": "^6.4.2",
    "babel-jest": "^29.7.0",
    "eslint": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "supertest": "^6.3.4"
  }
}
