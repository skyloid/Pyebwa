# Enable CORS for Firebase Authentication
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "https://www.pyebwa.com"
    Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type, Authorization"
    Header set Access-Control-Allow-Credentials "true"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # HSTS - enforce HTTPS
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# Protect sensitive files
<FilesMatch "^(\.env|\.git|serviceAccountKey\.json|.*\.log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect sensitive directories
<DirectoryMatch "^(.*/)?(\.(git|vscode)|node_modules|logs|secure|scripts|server)/">
    Order allow,deny
    Deny from all
</DirectoryMatch>

# Set default index file
DirectoryIndex index.html

# Service Worker handling
<FilesMatch "sw\.js|firebase-messaging-sw\.js">
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache"
</FilesMatch>

# Prevent directory browsing
Options -Indexes

# Enable gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# Disable all caching during testing
<IfModule mod_headers.c>
    # Prevent all caching
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
    
    # Ensure fresh content for all file types
    <FilesMatch "\.(html|css|js|json|xml|txt|jpg|jpeg|png|gif|svg|ico|woff|woff2|ttf|eot)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>