# Copy to .env and replace every placeholder before starting the stack.

COMPOSE_PROJECT_NAME=pyebwasupabase

# Network and published ports
PYEBWA_KONG_HTTP_PORT=8201
PYEBWA_AUTH_DEBUG_PORT=10998
PYEBWA_REST_DEBUG_PORT=14939

# Images
# Review and pin these to the exact versions validated for your migration.
POSTGRES_IMAGE=supabase/postgres:15.1.0.117
KONG_IMAGE=kong:2.8.1
GOTRUE_IMAGE=supabase/gotrue:v2.90.0
POSTGREST_IMAGE=postgrest/postgrest:v11.1.0
REALTIME_IMAGE=supabase/realtime:latest
STORAGE_IMAGE=supabase/storage-api:v0.40.4
META_IMAGE=supabase/postgres-meta:v0.68.0
IMGPROXY_IMAGE=darthsim/imgproxy:v3.8.0
STUDIO_IMAGE=supabase/studio:latest

# Database
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-new-pyebwa-postgres-password
PYEBWA_REALTIME_DB_USER=realtime_admin
PYEBWA_REALTIME_DB_PASSWORD=replace-with-new-pyebwa-realtime-password
PYEBWA_DB_PORT=5545

# Supabase and JWT
JWT_SECRET=replace-with-new-pyebwa-jwt-secret
ANON_KEY=replace-with-new-pyebwa-anon-jwt
SERVICE_KEY=replace-with-new-pyebwa-service-role-jwt

# Public URLs
SITE_URL=https://rasin.pyebwa.com
API_EXTERNAL_URL=https://rasin.pyebwa.com/supabase
SUPABASE_PUBLIC_URL=https://rasin.pyebwa.com/supabase

# Auth
GOTRUE_SITE_URL=https://rasin.pyebwa.com
GOTRUE_URI_ALLOW_LIST=https://rasin.pyebwa.com/login.html,https://rasin.pyebwa.com/reset-password.html,https://rasin.pyebwa.com/login,https://rasin.pyebwa.com/signup,http://127.0.0.1:9211/login,http://127.0.0.1:9211/reset-password
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_JWT_EXP=3600

# Service internal URLs
PYEBWA_DB_HOST=pyebwa-db
PYEBWA_AUTH_HOST=pyebwa-auth
PYEBWA_REST_HOST=pyebwa-rest
PYEBWA_STORAGE_HOST=pyebwa-storage
PYEBWA_META_HOST=pyebwa-meta
PYEBWA_IMGPROXY_HOST=pyebwa-imgproxy
PYEBWA_REALTIME_HOST=pyebwa-realtime
PYEBWA_STUDIO_HOST=pyebwa-studio
PYEBWA_KONG_HOST=pyebwa-kong

# Studio bootstrap
STUDIO_DEFAULT_ORGANIZATION=Pyebwa
STUDIO_DEFAULT_PROJECT=Pyebwa Production
