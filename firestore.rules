rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Family Trees - Users can only access their own family data
    match /family_trees/{familyId} {
      // Allow read/write if user is owner or has been granted access
      allow read, write: if isOwnerOrMember(familyId);
      
      // Family members sub-collection
      match /members/{memberId} {
        allow read, write: if isOwnerOrMember(familyId);
        
        // Member photos sub-collection
        match /photos/{photoId} {
          allow read, write: if isOwnerOrMember(familyId);
        }
      }
      
      // Family relationships sub-collection
      match /relationships/{relationshipId} {
        allow read, write: if isOwnerOrMember(familyId);
      }
      
      // Family events sub-collection
      match /events/{eventId} {
        allow read, write: if isOwnerOrMember(familyId);
      }
      
      // Family invitations sub-collection
      match /invitations/{invitationId} {
        // Owner can create/manage invitations
        allow read, write: if isOwner(familyId);
        // Invited user can read their invitation
        allow read: if resource.data.invitedEmail == request.auth.token.email;
        // Invited user can update invitation status (accept/decline)
        allow update: if resource.data.invitedEmail == request.auth.token.email
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'respondedAt']);
      }
    }
    
    // User profiles - Users can only access their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Validate user profile data structure
      allow create, update: if request.auth != null 
                           && request.auth.uid == userId
                           && validateUserProfile();
    }
    
    // User settings - Private to each user
    match /user_settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Search analytics - Only authenticated users can write
    match /search_analytics/{analyticsId} {
      allow read: if request.auth != null && isOwnerOrMember(resource.data.familyId);
      allow create: if request.auth != null && validateAnalytics();
    }
    
    // Public family trees (if enabled by owner)
    match /public_trees/{familyId} {
      allow read: if resource.data.isPublic == true;
      allow write: if request.auth != null && isOwner(familyId);
    }
    
    // System collections (admin only)
    match /system/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(familyId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/family_trees/$(familyId)) &&
             get(/databases/$(database)/documents/family_trees/$(familyId)).data.ownerId == request.auth.uid;
    }
    
    function isOwnerOrMember(familyId) {
      return isAuthenticated() && (
        // Check if user is owner
        isOwner(familyId) ||
        // Check if user is in members list
        request.auth.uid in get(/databases/$(database)/documents/family_trees/$(familyId)).data.memberIds ||
        // Check if user has accepted invitation
        exists(/databases/$(database)/documents/family_trees/$(familyId)/invitations/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/family_trees/$(familyId)/invitations/$(request.auth.uid)).data.status == 'accepted'
      );
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.admin == true;
    }
    
    function validateUserProfile() {
      let data = request.resource.data;
      return data.keys().hasAll(['displayName', 'email', 'createdAt']) &&
             data.displayName is string &&
             data.displayName.size() > 0 &&
             data.displayName.size() <= 100 &&
             data.email is string &&
             data.email == request.auth.token.email &&
             data.createdAt is timestamp;
    }
    
    function validateAnalytics() {
      let data = request.resource.data;
      return data.keys().hasAll(['userId', 'familyId', 'searchQuery', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.searchQuery is string &&
             data.searchQuery.size() <= 500 &&
             data.timestamp is timestamp;
    }
    
    function validateFamilyTree() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'ownerId', 'createdAt', 'memberIds']) &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() <= 200 &&
             data.ownerId == request.auth.uid &&
             data.memberIds is list &&
             data.memberIds.size() <= 1000 && // Max 1000 members per family
             data.createdAt is timestamp;
    }
    
    function validateFamilyMember() {
      let data = request.resource.data;
      return data.keys().hasAll(['firstName', 'lastName', 'addedBy', 'addedAt']) &&
             data.firstName is string &&
             data.firstName.size() > 0 &&
             data.firstName.size() <= 100 &&
             data.lastName is string &&
             data.lastName.size() <= 100 &&
             data.addedBy == request.auth.uid &&
             data.addedAt is timestamp;
    }
    
    // Rate limiting for search analytics (prevent spam)
    function isWithinRateLimit() {
      return resource == null || 
             request.time > resource.data.timestamp + duration.value(1, 's'); // 1 search per second per user
    }
  }
}

// Storage rules for user uploaded content
service firebase.storage {
  match /b/{bucket}/o {
    // Family photos - only accessible by family members
    match /families/{familyId}/photos/{photoId} {
      allow read, write: if request.auth != null && 
                        canAccessFamily(familyId);
      
      // Limit file size to 10MB
      allow write: if request.resource.size < 10 * 1024 * 1024;
      
      // Only allow image files
      allow write: if request.resource.contentType.matches('image/.*');
    }
    
    // User profile photos
    match /users/{userId}/profile/{photoId} {
      allow read, write: if request.auth != null && 
                        request.auth.uid == userId;
      
      // Limit file size to 5MB
      allow write: if request.resource.size < 5 * 1024 * 1024;
      
      // Only allow image files
      allow write: if request.resource.contentType.matches('image/.*');
    }
    
    // Temporary uploads (for processing)
    match /temp/{userId}/{fileName} {
      allow write: if request.auth != null && 
                  request.auth.uid == userId;
      
      // Temporary files expire after 1 hour
      allow read: if request.auth != null && 
                 request.auth.uid == userId &&
                 resource.timeCreated > request.time - duration.value(1, 'h');
      
      // Clean up - allow delete for own temp files
      allow delete: if request.auth != null && 
                   request.auth.uid == userId;
    }
    
    function canAccessFamily(familyId) {
      // Storage rules cannot directly query Firestore.
      // Deny by default — use Cloud Functions to validate access
      // before generating signed upload/download URLs.
      return false;
    }
  }
}