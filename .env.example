# Server Configuration
NODE_ENV=production
PORT=9111
DOMAIN=rasin.pyebwa.com

# Firebase Configuration (DO NOT commit real values)
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_auth_domain
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin SDK (use environment variable or secure key management)
FIREBASE_SERVICE_ACCOUNT_PATH=/secure/path/to/serviceAccountKey.json
# OR use individual credentials
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account-email

# Admin Setup
ADMIN_SETUP_KEY=generate_a_secure_admin_setup_key_here

# Security Configuration
SESSION_SECRET=generate_a_secure_random_string_here
JWT_SECRET=generate_another_secure_random_string_here
ALLOWED_ORIGINS=https://www.pyebwa.com,https://pyebwa.com,https://rasin.pyebwa.com
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
SESSION_COOKIE_MAX_AGE=86400000
ENABLE_CONCURRENT_SESSION_CHECK=true

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@pyebwa.com

# FTP Configuration (for legacy deployments)
FTP_HOST=your_ftp_host
FTP_PORT=21
FTP_USER=your_ftp_user
FTP_PASS=your_ftp_password

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_MONITORING=true
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Redis Configuration (for distributed rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password